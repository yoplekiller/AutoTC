# Groq AI
GROQ_API_KEY=your_groq_api_key

# Jira
JIRA_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=your@email.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_PROJECT_KEY=PROJ

# Google Sheets
SPREADSHEET_ID=your_spreadsheet_id
